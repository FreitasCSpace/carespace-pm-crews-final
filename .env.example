# CareSpace Autonomous PM — Environment Variables
# Copy to .env and fill in your values

# ── Required ──────────────────────────────────────────────
CLICKUP_API_TOKEN=pk_xxxxxxxxxxxxxxxxxxxx
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# ── Vanta (compliance_crew + exec_report_crew) ────────────
# Create API client at: app.vanta.com > Settings > API
# Scopes needed: vanta-api.all:read
VANTA_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VANTA_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Slack (all crews post to Slack) ───────────────────────
# Create app at: api.slack.com > Your Apps > Create
# Scopes: chat:write, channels:read
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxxxxxxxxxx

# ── LLM Model (default: gpt-4o) ──────────────────────────
# OPENAI_MODEL_NAME=gpt-4o
